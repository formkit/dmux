#!/bin/bash
set -euo pipefail
source "$DMUX_ROOT/.dmux-hooks/lib/attentive.sh"

[ "${DMUX_SKIP_PRE_MERGE:-0}" = "1" ] && exit 0

cd "$DMUX_WORKTREE_PATH"

CHANGED_MODULES=$(get_changed_gradle_modules)

if [ -n "$CHANGED_MODULES" ]; then
  echo "[Hook] Running Gradle checks for: $CHANGED_MODULES"
  TASKS=$(echo "$CHANGED_MODULES" | awk '{for(i=1;i<=NF;i++) printf $i":checkstyleMain " $i":test "}')
  ./gradlew $TASKS
else
  echo "[Hook] No Gradle modules changed, skipping checks"
fi
